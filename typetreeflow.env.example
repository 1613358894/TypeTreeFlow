# Copy this file to a local ignored env file such as lpsn.env or .env.local.
# Do not commit real credentials.

TYPETREEFLOW_EMAIL=your_ncbi_entrez_email@example.org
TYPETREEFLOW_API_KEY=

# LPSN official API credentials. Use either username or email plus password.
TYPETREEFLOW_LPSN_EMAIL=your_lpsn_account_email@example.org
TYPETREEFLOW_LPSN_USERNAME=
TYPETREEFLOW_LPSN_PASSWORD=
